{
  "manifest_version": 3,
  "name": "LinkedIn Growth Tool - Helper",
  "version": "1.0.0",
  "description": "Helper extension to safely sync session cookies with the local LinkedIn Growth dashboard.",
  "permissions": [
    "cookies",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
