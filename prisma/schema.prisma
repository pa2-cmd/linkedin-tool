datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model ProfileSnapshot {
  id         String   @id @default(cuid())
  headline   String
  about      String
  experience String?
  skills     String?
  score      Int?
  aiRewrites String?  // JSON string of 3 variants
  createdAt  DateTime @default(now())
}

model PostHistory {
  id           String    @id @default(cuid())
  topic        String
  format       String    // thought_leadership | carousel | hook_spark | commentary
  tone         String
  content      String
  hashtags     String?   // JSON array
  score        Int?      // editor agent score
  status       String    @default("draft") // draft | scheduled | published
  scheduledFor DateTime?
  createdAt    DateTime  @default(now())
}

model WeeklyMetrics {
  id                String   @id @default(cuid())
  weekStart         DateTime
  connections       Int      @default(0)
  profileViews      Int      @default(0)
  searchAppearances Int      @default(0)
  postImpressions   Int      @default(0)
  engagementRate    Float    @default(0)
  createdAt         DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String   // user | assistant
  content   String
  createdAt DateTime @default(now())
}

model LinkedProfile {
  id             String    @id @default(cuid())
  linkedinId     String    @unique
  name           String
  email          String?
  profilePicUrl  String?
  accessToken    String
  tokenExpiresAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

